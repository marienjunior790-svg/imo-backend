# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://immotec:immotec_dev@localhost:5432/immo_tec?schema=public"

# JWT
JWT_ACCESS_SECRET=immo-tec-dev-access-secret-key-32chars!!
JWT_REFRESH_SECRET=immo-tec-dev-refresh-secret-key-32chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (phase backend)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App
DEFAULT_CURRENCY=XAF
DEFAULT_CITY=Brazzaville
DEFAULT_COUNTRY=CG

# OpenAI (Assistant IA — optionnel, mode local sans clé)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# n8n Automation
N8N_ENABLED=false
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=immo-tec-automation-key-32chars-min

# CORS (production) — origines séparées par des virgules (frontend web)
# CORS_ORIGINS=https://app.example.com
# URL publique Railway (logs au démarrage)
# PUBLIC_API_URL=https://votre-api.up.railway.app
# Premier super-admin plateforme (créé une seule fois si aucun SUPER_ADMIN en base)
# BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@votre-domaine.cg
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=changez-moi-en-production

# P4 Identity & Security
PASSWORD_RESET_TTL_HOURS=1
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15

